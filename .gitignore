# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/

# Virtual environment
.venv/
venv/
env/

# Runtime/process state
.app.lock
.app.pid
.worker.lock
.worker.pid
*.log

# Job queue / job status databases
*.sqlite3
*.sqlite3-shm
*.sqlite3-wal

# User uploads and generated job output (large, ephemeral)
uploads/

# Downloaded model weights / caches (large binaries, fetched at runtime)
models_cache/
gfpgan/

# Test fixtures that may include large media samples
test_assets/

# Editor/OS noise
.idea/
.vscode/
*.DS_Store
Thumbs.db
